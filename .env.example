POSTGRES_USER=shalem
POSTGRES_PASSWORD=change-me-in-production
REDIS_PASSWORD=change-me-in-production

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-in-production

NEXT_PUBLIC_MEDPLUM_BASE_URL=http://localhost:8103/
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080/
NEXT_PUBLIC_KEYCLOAK_REALM=shalem-care
NEXT_PUBLIC_KEYCLOAK_CLIENT=shalem-web

MEDPLUM_CLIENT_ID=
MEDPLUM_CLIENT_SECRET=

# Storage Driver: "memory" (default, demo) oder "medplum" (Pilot/Production)
SHALEM_STORE=memory

# Demo-Mode: blendet Hinweis-Banner ein, zeigt Test-Personas im Header.
# Auf shalem.de Demo-Domain auf "1" setzen, in Prod-Mandanten leer lassen.
NEXT_PUBLIC_DEMO_MODE=

# Stripe (leer = mock-modus für PoC)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── KI für Pflegedoku ──────────────────────────────────
# Ohne API-Key läuft Mock-Provider (deterministische Demo-Antworten).
# Siehe docs/AI_INTEGRATION.md für DSGVO-Hinweise und Provider-Vergleich.

# DeepSeek (kostengünstig, ~0,1 ct pro Doku-Eintrag — KEIN AVV out-of-box, nur für Demo)
DEEPSEEK_API_KEY=

# Optional: Provider-Auswahl. Default "auto" = DeepSeek wenn Key gesetzt, sonst Mock
SHALEM_AI_PROVIDER=auto
SHALEM_AI_MODEL=deepseek-chat
