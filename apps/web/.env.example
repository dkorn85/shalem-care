# Shalem Care · Environment-Beispiel
# Diese Variablen lesen wir in lib/db/supabase.ts und lib/klient/db-driver.ts.
# Lokal: kopiere zu .env.local und fülle aus. .env.local ist gitignored.
# Production (Hostinger): in hPanel → Node.js → Environment Variables setzen.

# ─── Supabase (Phase-2-DB) ──────────────────────────────────────────────
# Wenn beide Variablen gesetzt sind, liest die App Klient:innen aus der DB.
# Wenn leer: Fallback auf in-memory Seed (Phase-1-Verhalten).

NEXT_PUBLIC_SUPABASE_URL=https://gpchwlqeqejxvynewjns.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Demo-Mode (vorhandener Toggle) ─────────────────────────────────────
# 1 = Demo-Banner + Persona-Switcher anzeigen.

NEXT_PUBLIC_DEMO_MODE=1
