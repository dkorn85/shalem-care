# Shalem Care · Environment-Beispiel
# Diese Variablen lesen wir in lib/db/supabase.ts und lib/klient/db-driver.ts.
# Lokal: kopiere zu .env.local und fülle aus. .env.local ist gitignored.
# Production (Hostinger): in hPanel → Node.js → Environment Variables setzen.

# ─── Supabase (Phase-2-DB) ──────────────────────────────────────────────
# Wenn beide Variablen gesetzt sind, liest die App Klient:innen aus der DB.
# Wenn leer: Fallback auf in-memory Seed (Phase-1-Verhalten).

# Lokal (Browser-exposed via NEXT_PUBLIC_*-Prefix):
NEXT_PUBLIC_SUPABASE_URL=https://gpchwlqeqejxvynewjns.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Hostinger injiziert automatisch (server-only, sicherer):
# SUPABASE_URL=...
# SUPABASE_ANON_KEY=...

# ─── Demo-Mode (vorhandener Toggle) ─────────────────────────────────────
# 1 = Demo-Banner + Persona-Switcher anzeigen.

NEXT_PUBLIC_DEMO_MODE=1

# ─── KI-Provider (lib/ai/provider.ts) ──────────────────────────────────
# SHALEM_AI_PROVIDER: "auto" (Default · nimmt was an Keys da ist),
#                    "anthropic" · "deepseek" · "mock"
# SHALEM_AI_MODEL  : optional, überschreibt das Default-Modell des Providers.
#
# NIE mit NEXT_PUBLIC_*-Prefix versehen — Keys MÜSSEN server-only bleiben.
# Lokal: in .env.local eintragen (gitignored).
# Production: in hPanel → Node.js → Environment Variables setzen.

# Anthropic (Claude) — Key holen unter: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# SHALEM_AI_MODEL=claude-haiku-4-5-20251001   # schnell + günstig (Default)
# SHALEM_AI_MODEL=claude-sonnet-4-6           # Allrounder
# SHALEM_AI_MODEL=claude-opus-4-7             # höchste Qualität

# DeepSeek (Alternative)
# DEEPSEEK_API_KEY=

# Provider hart wählen statt auto-Erkennung:
# SHALEM_AI_PROVIDER=anthropic
